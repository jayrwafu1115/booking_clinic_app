# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI — set OPENAI_BASE_URL to use an OpenAI-compatible provider (e.g. Groq, Together)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Book Clinic PH <notifications@bookclinicph.com>"

# Payments (PayMongo)
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_SUCCESS_REDIRECT_URL=http://localhost:3000/billing/success
PAYMONGO_CANCEL_REDIRECT_URL=http://localhost:3000/billing/cancelled

# SMS — Semaphore (recommended for Philippine mobile numbers)
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=

# Upstash Redis — enables multi-instance rate limiting (replaces in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron — protects /api/cron/* routes from unauthorized calls
# Vercel sets this automatically; generate any random secret for local/self-hosted.
CRON_SECRET=
